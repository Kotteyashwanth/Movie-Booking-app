<mvc:View
    controllerName="project1.controller.MovieDetails"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core">

    <Page title="Movie Details" showNavButton="true" navButtonPress="onBack">

        <content>
            <ScrollContainer height="100%" vertical="true" horizontal="false">
                <VBox class="sapUiSmallMargin" width="100%">

                    <HBox width="100%" alignItems="Start" justifyContent="Start" wrap="NoWrap">

                        <!-- Poster -->
                        <VBox width="550px" class="sapUiSmallMarginEnd">
                            <Image
                                src="{= ${app>/selectedMovie/poster} || '' }"
                                width="550px"
                                height="650px"
                                densityAware="false" />
                        </VBox>

                        <!-- Details -->
                        <VBox fitContainer="true" width="100%" class="sapUiSmallMarginBegin">

                            <Title
                                text="{= ${app>/selectedMovie/title} || 'N/A' }"
                                level="H1"
                                class="movieDetailTitle sapUiSmallMarginBottom" />

                            <HBox width="100%" class="sapUiTinyMarginBottom" alignItems="Center">
                                <Text text="Genre" width="145px" class="movieDetailLabel" />
                                <Text text=":" width="20px" class="movieDetailColon" />
                                <Text text="{= ${app>/selectedMovie/genre} || 'N/A' }" wrapping="true" class="movieDetailValue" />
                            </HBox>

                            <HBox width="100%" class="sapUiTinyMarginBottom" alignItems="Center">
                                <Text text="Release Date" width="145px" class="movieDetailLabel" />
                                <Text text=":" width="20px" class="movieDetailColon" />
                                <Text text="{= ${app>/selectedMovie/release} || 'N/A' }" wrapping="true" class="movieDetailValue" />
                            </HBox>

                            <HBox width="100%" class="sapUiTinyMarginBottom" alignItems="Center">
                                <Text text="Duration" width="145px" class="movieDetailLabel" />
                                <Text text=":" width="20px" class="movieDetailColon" />
                                <Text text="{= ${app>/selectedMovie/duration} || 'N/A' }" wrapping="true" class="movieDetailValue" />
                            </HBox>

                            <!-- Cast & Crew Heading -->
                            <Title
                                text="Cast &amp; Crew"
                                level="H3"
                                class="sapUiSmallMarginTop sapUiSmallMarginBottom" />

                            <HBox width="100%" class="sapUiTinyMarginBottom" alignItems="Center">
                                <Text text="Hero" width="145px" class="movieDetailLabel" />
                                <Text text=":" width="20px" class="movieDetailColon" />
                                <Text text="{= ${app>/selectedMovie/hero} || 'N/A' }" wrapping="true" class="movieDetailValue" />
                            </HBox>

                            <HBox width="100%" class="sapUiTinyMarginBottom" alignItems="Center">
                                <Text text="Heroine" width="145px" class="movieDetailLabel" />
                                <Text text=":" width="20px" class="movieDetailColon" />
                                <Text text="{= ${app>/selectedMovie/heroine} || 'N/A' }" wrapping="true" class="movieDetailValue" />
                            </HBox>

                            <HBox width="100%" class="sapUiTinyMarginBottom" alignItems="Center">
                                <Text text="Director" width="145px" class="movieDetailLabel" />
                                <Text text=":" width="20px" class="movieDetailColon" />
                                <Text text="{= ${app>/selectedMovie/director} || 'N/A' }" wrapping="true" class="movieDetailValue" />
                            </HBox>

                            <HBox width="100%" class="sapUiTinyMarginBottom" alignItems="Center">
                                <Text text="Producer" width="145px" class="movieDetailLabel" />
                                <Text text=":" width="20px" class="movieDetailColon" />
                                <Text text="{= ${app>/selectedMovie/producer} || 'N/A' }" wrapping="true" class="movieDetailValue" />
                            </HBox>

                            <HBox width="100%" class="sapUiTinyMarginBottom" alignItems="Center">
                                <Text text="Music Director" width="145px" class="movieDetailLabel" />
                                <Text text=":" width="20px" class="movieDetailColon" />
                                <Text text="{= ${app>/selectedMovie/musicDirector} || 'N/A' }" wrapping="true" class="movieDetailValue" />
                            </HBox>

                            <HBox width="100%" class="sapUiTinyMarginBottom" alignItems="Center">
                                <Text text="Cinematography" width="145px" class="movieDetailLabel" />
                                <Text text=":" width="20px" class="movieDetailColon" />
                                <Text text="{= ${app>/selectedMovie/cinematography} || 'N/A' }" wrapping="true" class="movieDetailValue" />
                            </HBox>

                            <HBox width="100%" class="sapUiTinyMarginBottom" alignItems="Center">
                                <Text text="Editor" width="145px" class="movieDetailLabel" />
                                <Text text=":" width="20px" class="movieDetailColon" />
                                <Text text="{= ${app>/selectedMovie/editor} || 'N/A' }" wrapping="true" class="movieDetailValue" />
                            </HBox>

                            <Title text="Synopsis" level="H3" class="sapUiSmallMarginTop sapUiSmallMarginBottom" />
                            <Text text="{= ${app>/selectedMovie/synopsis1} || 'N/A' }" wrapping="true" class="movieDetailValue" />
                            <Text text="{= ${app>/selectedMovie/synopsis2} || '' }" wrapping="true" class="movieDetailValue sapUiTinyMarginTop" />

                        </VBox>
                    </HBox>
                </VBox>
            </ScrollContainer>
        </content>

        <footer>
            <OverflowToolbar>
                <ToolbarSpacer />
                <Button
                    text="Book Tickets"
                    type="Emphasized"
                    press="onBookTickets" />
                <ToolbarSpacer />
            </OverflowToolbar>
        </footer>

    </Page>
</mvc:View>