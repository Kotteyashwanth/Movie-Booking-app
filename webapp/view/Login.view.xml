<mvc:View
    controllerName="project1.controller.Login"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    displayBlock="true">

    <Page
        showHeader="false"
        class="loginPage">

        <content>

            <VBox
                class="loginOuter"
                width="100%"
                height="100%"
                justifyContent="Center"
                alignItems="Center">

                <VBox
                    class="loginBox"
                    width="22rem"
                    alignItems="Stretch">

                    <Text
                        text="MOVIE TICKET APP"
                        class="appTitle"
                        textAlign="Center" />

                    <Text
                        text="Customer Login"
                        class="appSubTitle"
                        textAlign="Center" />

                    <Label
                        text="Email"
                        required="true"
                        class="formLabel" />

                    <Input
                        id="identifierInput"
                        value="{/identifier}"
                        width="100%"
                        placeholder="Enter your email" />

                    <Label
                        text="Password"
                        required="true"
                        class="formLabel" />

                    <Input
                        id="passwordInput"
                        type="Password"
                        value="{/password}"
                        width="100%"
                        placeholder="Enter your password"
                        showValueHelp="true"
                        valueHelpIconSrc="sap-icon://hide"
                        valueHelpRequest="onTogglePassword" />

                    <Button
                        text="Login"
                        type="Emphasized"
                        width="100%"
                        press="onLogin"
                        class="signupButton" />

                    <Link
                        text="Forgot Password?"
                        press="onForgotPassword"
                        class="smallLink" />

                    <HBox
                        justifyContent="Center"
                        class="signupRow">

                        <Text text="Don't have an account?" />

                        <Link
                            text=" Create Account"
                            press="onCreateAccount" />

                    </HBox>

                    <Text
                        text="{/message}"
                        class="messageText" />

                </VBox>

            </VBox>

        </content>

    </Page>

</mvc:View>