<mvc:View
    controllerName="project1.controller.Register"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    displayBlock="true">

    <Page
        showHeader="false"
        class="loginPage">

        <content>

            <VBox
                class="loginOuter"
                width="100%"
                height="100%"
                justifyContent="Center"
                alignItems="Center">

                <VBox
                    class="loginBox"
                    width="22rem"
                    alignItems="Stretch">

                    <!-- TITLE -->
                    <Text
                        text="CREATE ACCOUNT"
                        class="appTitle"
                        textAlign="Center" />

                    <Text
                        text="Register as a customer"
                        class="appSubTitle"
                        textAlign="Center" />

                    <!-- FULL NAME -->
                    <Label
                        text="Full Name"
                        required="true"
                        class="formLabel" />

                    <Input
                        id="nameInput"
                        value="{/name}"
                        placeholder="Enter full name"
                        width="100%" />

                    <!-- EMAIL -->
                    <Label
                        text="Email"
                        required="true"
                        class="formLabel" />

                    <Input
                        id="emailInput"
                        value="{/email}"
                        placeholder="Enter email"
                        width="100%"
                        type="Email" />

                    <!-- PHONE -->
                    <Label
                        text="Phone Number"
                        required="true"
                        class="formLabel" />

                    <Input
                        id="phoneInput"
                        value="{/phone}"
                        placeholder="Enter 10-digit phone number"
                        width="100%"
                        type="Tel"
                        maxLength="10"
                        liveChange="onPhoneLiveChange" />

                    <!-- PASSWORD -->
                    <Label
                        text="Password"
                        required="true"
                        class="formLabel" />

                    <Input
                        id="passwordInput"
                        type="Password"
                        value="{/password}"
                        placeholder="Enter password"
                        width="100%"
                        showValueHelp="true"
                        valueHelpIconSrc="sap-icon://hide"
                        valueHelpRequest="onTogglePassword" />

                    <!-- CONFIRM PASSWORD -->
                    <Label
                        text="Confirm Password"
                        required="true"
                        class="formLabel" />

                    <Input
                        id="confirmPasswordInput"
                        type="Password"
                        value="{/confirmPassword}"
                        placeholder="Confirm password"
                        width="100%"
                        showValueHelp="true"
                        valueHelpIconSrc="sap-icon://hide"
                        valueHelpRequest="onToggleConfirmPassword" />

                    <!-- SIGN UP -->
                    <Button
                        text="Sign Up"
                        type="Emphasized"
                        width="100%"
                        press="onSignUp"
                        class="signupButton" />

                    <!-- BACK -->
                    <Link
                        text="Back to Login"
                        press="onBack"
                        class="smallLink" />

                    <!-- MESSAGE -->
                    <Text
                        text="{/message}"
                        class="messageText" />

                </VBox>

            </VBox>

        </content>

    </Page>

</mvc:View>