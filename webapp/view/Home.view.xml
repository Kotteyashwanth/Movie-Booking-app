<mvc:View
    controllerName="project1.controller.Home"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    displayBlock="true">

    <Page class="homePage" showHeader="true" enableScrolling="true">

        <!-- HEADER -->
        <customHeader>

            <Toolbar class="homeToolbar navbar">

                <!-- LOGO -->
                <HBox alignItems="Center" class="logoSection">

                    <Image
                        src="images/cineverse-logo.png"
                        width="90px"
                        height="90px"
                        class="logoImage" />

                    <Text
                        text="CineVerse"
                        class="logoText" />

                </HBox>

                <ToolbarSpacer />

                <!-- MENU -->
                <HBox
                    alignItems="Center"
                    class="menuSection">

                    <Button
                        text="Home"
                        type="Transparent"
                        press="onHomePress"
                        class="menuItemBtn" />

                    <Button
                        text="Movies"
                        type="Transparent"
                        press="onMoviesPress"
                        class="menuItemBtn" />

                    <Button
                        text="My Tickets"
                        type="Transparent"
                        press="onTicketsPress"
                        class="menuItemBtn" />

                    <Button
                        text="Offers"
                        type="Transparent"
                        press="onOffersPress"
                        class="menuItemBtn" />

                </HBox>

                <ToolbarSpacer />

                <!-- SEARCH -->
                <SearchField
                    width="16rem"
                    placeholder="Search movies"
                    liveChange="onSearch"
                    class="headerSearch" />

                <!-- NOTIFICATION -->
                <Button
                    icon="sap-icon://bell"
                    type="Transparent"
                    class="headerBellBtn sapUiSmallMarginBegin" />

                <!-- PROFILE -->
                <HBox
                    alignItems="Center"
                    renderType="Bare"
                    visible="{= !!${user>/loggedIn} }"
                    class="sapUiSmallMarginBegin">

                    <Avatar
                        initials="{user>/initials}"
                        displaySize="S"
                        class="sapUiTinyMarginEnd" />

                    <MenuButton type="Transparent">
                        <menu>
                            <Menu>
                                <MenuItem
                                    text="Logout"
                                    icon="sap-icon://log"
                                    press="onLogout" />
                            </Menu>
                        </menu>
                    </MenuButton>

                </HBox>

            </Toolbar>

        </customHeader>

        <!-- SEARCH -->
        <subHeader>
            <Toolbar class="homeToolbar">

                <Title
                    text="SPOTLIGHT"
                    level="H2"
                    class="sectionTitle" />

            </Toolbar>
        </subHeader>

        <content>

            <!-- HERO SLIDER -->
            <VBox class="heroSliderWrapper">

                <Carousel
                    id="heroCarousel"
                    loop="true"
                    showPageIndicator="false"
                    width="100%"
                    height="460px"
                    class="heroCarousel">

                    <pages>

                        <!-- ROWDY JANARDHANA -->
                        <VBox class="heroSlide">
                            <VBox class="bannerWrapper rowdyBannerWrapper">

                                <Image
                                    src="images/vijay movie.png"
                                    width="100%"
                                    height="460px"
                                    densityAware="false"
                                    decorative="false"
                                    active="true"
                                    press="onBookNow"
                                    class="heroFullImage rowdyBannerImage" />

                                <VBox class="rowdyOverlay">

                                    <Text
                                        text="ACTION THRILLER"
                                        class="heroTag" />

                                    <Title
                                        text="ROWDY JANARDHANA"
                                        level="H1"
                                        class="rowdyMainTitle" />

                                    <Text
                                        text="The rage begins."
                                        class="heroSubText" />

                                    <Text
                                        text="{= ${/featuredMovie/release} + ' • ' + ${/featuredMovie/duration} }"
                                        class="heroSubText" />

                                    <Text
                                        text="{/featuredMovie/languages}"
                                        class="heroSubText" />

                                    <HBox class="detailRow sapUiMediumMarginTop">

                                        <VBox class="detailChip">
                                            <Text text="Release" class="detailLabel" />
                                            <Text text="{/featuredMovie/release}" class="detailValue" />
                                        </VBox>

                                        <VBox class="detailChip">
                                            <Text text="Hero" class="detailLabel" />
                                            <Text text="{= ${/featuredMovie/hero} || 'N/A' }" class="detailValue" />
                                        </VBox>

                                        <VBox class="detailChip">
                                            <Text text="Runtime" class="detailLabel" />
                                            <Text text="{/featuredMovie/duration}" class="detailValue" />
                                        </VBox>

                                        <VBox class="detailChip">
                                            <Text text="Language" class="detailLabel" />
                                            <Text text="{/featuredMovie/languages}" class="detailValue" />
                                        </VBox>

                                    </HBox>

                                    <HBox class="heroBtnRow">
                                        <Button
                                            text="Book Tickets"
                                            press="onBookNow"
                                            class="bookBtn" />

                                        <Button
                                            text="Watch Trailer"
                                            icon="sap-icon://media-play"
                                            press="onWatchTrailer"
                                            class="trailerBtn" />
                                    </HBox>

                                </VBox>

                            </VBox>
                        </VBox>

                        <!-- GTA -->
                        <VBox class="heroSlide">
                            <VBox class="gtaBannerWrapper">

                                <Image
                                    src="images/GTA-6.png"
                                    width="100%"
                                    height="460px"
                                    densityAware="false"
                                    decorative="false"
                                    active="true"
                                    press="onWatchGTATrailer"
                                    class="heroFullImage" />

                                <Button
                                    text="Watch Trailer"
                                    icon="sap-icon://media-play"
                                    press="onWatchGTATrailer"
                                    class="trailerBtn gtaBottomBtn" />

                            </VBox>

                        </VBox>

                        <!-- BANK OFFER -->
                        <VBox class="heroSlide">
                            <VBox class="bannerWrapper rowdyBannerWrapper">

                                <Image
                                    src="images/Axis card.jpg"
                                    width="100%"
                                    height="460px"
                                    densityAware="false"
                                    decorative="false"
                                    active="true"
                                    press="onAxisCardPress"
                                    class="heroFullImage rowdyBannerImage" />

                            </VBox>
                        </VBox>

                    </pages>

                </Carousel>

                <!-- SHARED DOTS -->
                <HBox class="heroDots">

                    <Button
                        id="heroDot0"
                        type="Transparent"
                        press="onHeroDotPress"
                        class="heroDot heroDotActive">

                        <customData>
                            <core:CustomData key="index" value="0" />
                        </customData>

                    </Button>

                    <Button
                        id="heroDot1"
                        type="Transparent"
                        press="onHeroDotPress"
                        class="heroDot">

                        <customData>
                            <core:CustomData key="index" value="1" />
                        </customData>

                    </Button>

                    <Button
                        id="heroDot2"
                        type="Transparent"
                        press="onHeroDotPress"
                        class="heroDot">

                        <customData>
                            <core:CustomData key="index" value="2" />
                        </customData>

                    </Button>

                </HBox>

            </VBox>

            <!-- MOVIES -->
            <VBox class="movieHeading">

                <Title
                    text="RECOMMENDED MOVIES"
                    level="H2"
                    class="sectionTitle" />

            </VBox>

            <VBox class="movieWrapper">

                <Button
                    icon="sap-icon://slim-arrow-left"
                    press="onScrollLeft"
                    class="scrollArrow leftArrow" />

                <Button
                    icon="sap-icon://slim-arrow-right"
                    press="onScrollRight"
                    class="scrollArrow rightArrow" />

                <ScrollContainer
                    id="movieScroller"
                    horizontal="true"
                    vertical="false"
                    width="100%"
                    height="420px"
                    focusable="false"
                    class="movieScroll">

                    <HBox
                        id="movieStrip"
                        items="{/movies}"
                        wrap="NoWrap"
                        class="movieRow">

                        <items>

                            <VBox class="movieCard">

                                <Image
                                    src="{poster}"
                                    width="250px"
                                    height="360px"
                                    decorative="false"
                                    densityAware="false"
                                    active="true"
                                    press="onMoviePress"
                                    class="moviePoster" />

                                <VBox class="movieInfo">

                                    <Title
                                        text="{title}"
                                        level="H4"
                                        class="movieTitleBold" />

                                    <Text
                                        text="{
                                            path: 'genre',
                                            formatter: '.formatGenre'
                                        }"
                                        class="movieGenre"
                                        wrapping="true" />

                                </VBox>

                            </VBox>

                        </items>

                    </HBox>

                </ScrollContainer>

            </VBox>

        </content>

    </Page>

</mvc:View>