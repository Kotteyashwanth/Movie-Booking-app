<mvc:View
    controllerName="project1.controller.Home"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    displayBlock="true">

    <Page class="homePage" showHeader="false">

        <customHeader>
            <Toolbar class="homeToolbar">

                <HBox alignItems="Center" renderType="Bare">
                    <core:Icon src="sap-icon://video" size="1.6rem" />
                    <Title text="Movie Ticket App" level="H2" class="sapUiSmallMarginBegin" />
                </HBox>

                <ToolbarSpacer />

                <HBox
                    alignItems="Center"
                    renderType="Bare"
                    visible="{= ${/user/loggedIn} }">

                    <Avatar
                        initials="{/user/initials}"
                        displaySize="S"
                        class="sapUiTinyMarginEnd" />

                    <VBox class="sapUiTinyMarginEnd">
                        <Text text="Welcome, {/user/displayName}" class="sapUiTinyMarginBottom" />
                        <Text text="{/user/email}" class="sapUiSmallFontSize" wrapping="false" />
                    </VBox>

                    <MenuButton icon="sap-icon://slim-arrow-down" type="Transparent">
                        <menu>
                            <Menu>
                                <MenuItem text="Logout" icon="sap-icon://log" press="onLogout" />
                            </Menu>
                        </menu>
                    </MenuButton>
                </HBox>

            </Toolbar>
        </customHeader>

        <subHeader>
            <Toolbar class="homeToolbar">
                <Title text="Recommended Movies" level="H2" />
                <ToolbarSpacer />
                <SearchField
                    width="18rem"
                    placeholder="Search movie"
                    liveChange="onSearch" />
            </Toolbar>
        </subHeader>

        <content>
            <VBox class="movieWrapper">

                <Button
                    icon="sap-icon://slim-arrow-left"
                    press="onScrollLeft"
                    class="scrollArrow leftArrow" />

                <Button
                    icon="sap-icon://slim-arrow-right"
                    press="onScrollRight"
                    class="scrollArrow rightArrow" />

                <ScrollContainer
                    id="movieScroller"
                    horizontal="true"
                    vertical="false"
                    width="100%"
                    height="100%"
                    focusable="false"
                    class="movieScroll">

                    <HBox
                        id="movieStrip"
                        items="{/movies}"
                        wrap="NoWrap"
                        class="movieRow">

                        <items>
                            <VBox class="movieCard">

                                <Image
                                    src="{poster}"
                                    width="250px"
                                    height="360px"
                                    decorative="false"
                                    densityAware="false"
                                    active="true"
                                    press="onMoviePress"
                                    class="moviePoster" />

                                <VBox class="movieInfo">
                                    <Title
                                        text="{title}"
                                        level="H4"
                                        class="movieTitleBold" />

                                    <Text
                                        text="{
                                            path: 'genre',
                                            formatter: '.formatGenre'
                                        }"
                                        class="movieGenre"
                                        wrapping="true" />
                                </VBox>

                            </VBox>
                        </items>

                    </HBox>

                </ScrollContainer>
            </VBox>
        </content>
    </Page>
</mvc:View>