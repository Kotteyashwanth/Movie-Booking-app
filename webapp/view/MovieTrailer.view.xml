<mvc:View
    controllerName="project1.controller.MovieTrailer"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core">

    <Page
        title="{= 'Videos for ' + (${app>/selectedMovie/title} || 'Movie') }"
        showNavButton="true"
        navButtonPress="onBack">

        <content>
            <ScrollContainer height="100%" vertical="true" horizontal="false">
                <VBox class="sapUiSmallMargin" width="100%">

                    <Title
                        text="{= 'Videos for ' + (${app>/selectedMovie/title} || 'Movie') }"
                        level="H2"
                        class="sapUiSmallMarginBottom" />

                    <SegmentedButton
                        id="languageSeg"
                        selectionChange="onTrailerLanguageChange"
                        items="{path: 'app>/selectedMovie/trailers'}">

                        <items>
                            <SegmentedButtonItem
                                key="{app>language}"
                                text="{app>language}" />
                        </items>
                    </SegmentedButton>

                    <VBox class="sapUiSmallMarginTop">
                        <core:HTML id="trailerHost" content="" />
                    </VBox>

                </VBox>
            </ScrollContainer>
        </content>

    </Page>
</mvc:View>